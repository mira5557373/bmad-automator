def test_get_resource(pact):
    """Example consumer contract test.

    Demonstrates the request/response expectation pattern.
    Replace the path, headers, and expected body with your real API shape.
    """
    expected_body = {"id": 1, "name": "${service_prefix}-resource"}

    (
        pact.given("a resource exists")
        .upon_receiving("a request for a resource")
        .with_request("GET", "/api/v1/resources/1")
        .will_respond_with(200, body=expected_body)
    )

    with pact:
        import requests

        result = requests.get(pact.uri + "/api/v1/resources/1")

    assert result.status_code == 200
    assert result.json()["name"] == "${service_prefix}-resource"
