def by_testid(testid):
    """Build a CSS selector targeting ``data-testid`` attributes.

    Prefer data-testid selectors over class/id selectors for test
    resilience — they survive CSS refactors and minification.
    """
    return f'[data-testid="{testid}"]'


def by_role(role, name=None):
    """Build an ARIA role selector with optional accessible name.

    Customize: extend with additional ARIA attributes as needed.
    """
    sel = f'[role="{role}"]'
    if name:
        sel += f'[aria-label="{name}"]'
    return sel


class SelectorChain:
    """Fallback chain: tries selectors in order until one matches.

    Usage::

        chain = SelectorChain(
            by_testid("submit-btn"),
            by_role("button", "Submit"),
            "button[type=submit]",
        )
        element = chain.locate(page)

    Customize: add logging or metrics to track which fallback level
    is hit — high fallback rates signal fragile selectors.
    """

    def __init__(self, *selectors):
        self.selectors = selectors

    def locate(self, page):
        """Try each selector; return the first match or raise."""
        for sel in self.selectors:
            loc = page.locator(sel)
            if loc.count() > 0:
                return loc
        raise LookupError(
            f"No element found for any selector in chain: {self.selectors}"
        )
