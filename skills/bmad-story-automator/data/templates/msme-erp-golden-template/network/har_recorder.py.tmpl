import json
import time
from pathlib import Path

import pytest


@pytest.fixture
def har_recorder(tmp_path):
    """Record HTTP traffic to a HAR file for the ${service_prefix} service.

    Usage in Playwright tests::

        def test_example(page, har_recorder):
            page.route_from_har(har_recorder.har_path)
            # ... test interactions ...

    Customize: for non-Playwright usage, integrate with mitmproxy
    or a network-level HAR capture tool.
    """
    recorder = HarRecorder(tmp_path / "${service_prefix}_traffic.har")
    yield recorder
    recorder.save()


class HarRecorder:
    """Minimal HAR 1.2 recorder for HTTP traffic capture."""

    def __init__(self, har_path):
        self.har_path = Path(har_path)
        self._entries = []
        self._start_time = time.time()

    def add_entry(self, method, url, status, request_body=None, response_body=None):
        """Record an HTTP transaction.

        Customize: add headers, cookies, and timing fields
        as needed for your debugging workflow.
        """
        self._entries.append({
            "startedDateTime": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "request": {
                "method": method,
                "url": url,
                "bodySize": len(request_body or ""),
            },
            "response": {
                "status": status,
                "bodySize": len(response_body or ""),
            },
        })

    def save(self):
        """Write the HAR log to disk."""
        har = {
            "log": {
                "version": "1.2",
                "creator": {"name": "${product_name}-har-recorder", "version": "1.0"},
                "entries": self._entries,
            }
        }
        self.har_path.parent.mkdir(parents=True, exist_ok=True)
        self.har_path.write_text(json.dumps(har, indent=2), encoding="utf-8")
