# ${product_name} — Health check endpoints
# Generated by the factory seed-template system.
#
# Customize: add readiness checks for your service's dependencies
# (database, cache, message broker, etc.).

from fastapi import FastAPI, Response

app = FastAPI(title="${service_prefix}-health")


@app.get("/healthz")
async def healthz():
    """Liveness probe — returns 200 if the process is running.

    Kubernetes uses this to decide whether to restart the container.
    Keep this cheap and side-effect-free.
    """
    return {"status": "ok", "service": "${service_prefix}"}


@app.get("/readyz")
async def readyz():
    """Readiness probe — returns 200 when the service can accept traffic.

    Customize: add dependency checks (DB connection, cache warmth, etc.)
    and return 503 if any dependency is not ready.
    """
    checks = {
        "self": True,
    }

    all_ready = all(checks.values())
    status_code = 200 if all_ready else 503
    return Response(
        content='{"status": "ready", "service": "' + "${service_prefix}" + '"}',
        media_type="application/json",
        status_code=status_code,
    )


if __name__ == "__main__":
    import uvicorn

    uvicorn.run(app, host="0.0.0.0", port=${health_port})
