# ${product_name} — SLO definitions
# Generated by the factory seed-template system.
#
# Customize: adjust targets, windows, and burn-rate alerts
# to match your service's SLA commitments.

service: ${service_prefix}

slos:
  - name: ${service_prefix}-availability
    description: Proportion of successful requests
    target: 0.999
    window: 30d
    indicator:
      type: request-based
      good: "http_status < 500"
      total: "all requests"

  - name: ${service_prefix}-latency-p99
    description: 99th percentile response time
    target: 0.99
    window: 30d
    indicator:
      type: threshold
      metric: http_request_duration_seconds
      threshold: 0.5

  - name: ${service_prefix}-error-rate
    description: Proportion of non-error responses
    target: 0.999
    window: 7d
    indicator:
      type: request-based
      good: "http_status < 500"
      total: "all requests"

burn_rate_alerts:
  - name: ${service_prefix}-fast-burn
    short_window: 5m
    long_window: 1h
    factor: 14.4

  - name: ${service_prefix}-slow-burn
    short_window: 30m
    long_window: 6h
    factor: 6.0
