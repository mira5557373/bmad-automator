#!/usr/bin/env node

const fs = require("node:fs");
const path = require("node:path");
const { spawnSync } = require("node:child_process");

const rootDir = path.resolve(__dirname, "..");
const installScript = path.join(rootDir, "install.sh");
const packageJson = JSON.parse(
  fs.readFileSync(path.join(rootDir, "package.json"), "utf8")
);
const args = process.argv.slice(2);

function resolveBash() {
  // On macOS/Linux the PATH "bash" is correct. On Windows the installer is a
  // pure file-copy bash script (install.sh validates dirs and cp -a's the skill
  // folders), so run it under any available POSIX bash (Git Bash / WSL) instead
  // of refusing the OS outright. Returns null when no bash can be located.
  if (process.platform !== "win32") {
    return "bash";
  }
  const candidates = [];
  if (process.env.SHELL) {
    candidates.push(process.env.SHELL);
  }
  const where = spawnSync("where", ["bash"], { encoding: "utf8" });
  if (where.status === 0 && typeof where.stdout === "string") {
    for (const line of where.stdout.split(/\r?\n/)) {
      const trimmed = line.trim();
      if (trimmed) {
        candidates.push(trimmed);
      }
    }
  }
  candidates.push(
    "C:\\Program Files\\Git\\bin\\bash.exe",
    "C:\\Program Files\\Git\\usr\\bin\\bash.exe"
  );
  for (const candidate of candidates) {
    try {
      if (candidate && fs.existsSync(candidate)) {
        return candidate;
      }
    } catch (_err) {
      /* ignore and try the next candidate */
    }
  }
  return null;
}

function printUsage() {
  console.log(`bmad-story-automator v${packageJson.version}

Usage:
  npx bmad-story-automator
  npx bmad-story-automator <bmad-project-root>

Options:
  -h, --help     Show help
  -v, --version  Show version
`);
}

if (args.includes("-h") || args.includes("--help")) {
  printUsage();
  process.exit(0);
}

if (args.includes("-v") || args.includes("--version")) {
  console.log(packageJson.version);
  process.exit(0);
}

if (args.length > 1) {
  printUsage();
  process.exit(1);
}

const bashCmd = resolveBash();
if (!bashCmd) {
  console.error(
    "Error: bash is required to install. On Windows, install Git for Windows " +
      "(provides Git Bash) or run inside WSL, then re-run this command."
  );
  process.exit(1);
}

const targetRoot = args.length === 0 ? process.cwd() : args[0];

const result = spawnSync(bashCmd, [installScript, targetRoot], {
  cwd: rootDir,
  stdio: "inherit"
});

if (result.error) {
  console.error(`Error: Failed to run installer: ${result.error.message}`);
  process.exit(1);
}

process.exit(result.status ?? 1);
