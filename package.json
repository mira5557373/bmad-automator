{
  "name": "bmad-story-automator",
  "version": "1.15.0",
  "description": "Install the BMAD story-automator self-contained skills into a BMAD project.",
  "license": "MIT",
  "bin": {
    "bmad-story-automator": "bin/bmad-story-automator"
  },
  "files": [
    "bin/",
    "docs/",
    "install.sh",
    "!docs/plans",
    "!docs/plans/**",
    "skills/",
    "!skills/bmad-story-automator/dist/",
    "!skills/**/__pycache__/",
    "!skills/**/*.pyc",
    "!skills/**/*.pyo",
    "!skills/**/tests/",
    "!docs/superpowers/",
    "!docs/plans/",
    "README.md",
    "ref.png",
    ".claude-plugin/"
  ],
  "scripts": {
    "build:python": "python3 -m build skills/bmad-story-automator",
    "test:cli": "PYTHONPATH=skills/bmad-story-automator/src python3 -m story_automator --help >/dev/null && skills/bmad-story-automator/scripts/story-automator --help >/dev/null",
    "pack:dry-run": "npm pack --dry-run",
    "test:python": "PYTHONPATH=skills/bmad-story-automator/src python3 -m unittest discover -s tests",
    "test:smoke": "bash scripts/smoke-test.sh",
    "lint:python": "ruff check skills tests",
    "gates:vocab": "sh scripts/m11-vocabulary-gates.sh",
    "verify": "npm run lint:python && npm run test:python && npm run pack:dry-run && npm run test:cli && npm run test:smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bmad",
    "claude",
    "codex",
    "workflow",
    "automation",
    "python"
  ]
}
